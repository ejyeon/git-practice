#!/bin/sh
# 파일 유형을 판단하여 출력하는 셸 프로그램

echo "파일/ 디렉토리 이름 입력 [enter]"
read filename   # 키보드 입력을 filename 변수에 저장

# ~ (틸드) 처리: eval로 홈 디렉토리 경로 확장
filename=$(eval echo "$filename")

if [ ! -e "$filename" ] && [ ! -L "$filename" ]; then
    echo "$filename 은(는) 존재하지 않습니다."
elif [ -L "$filename" ]; then
    echo "$filename 은(는) 심볼릭링크입니다."
elif [ -d "$filename" ]; then
    echo "$filename 은(는) 디렉토리입니다."
elif [ -c "$filename" ]; then
    echo "$filename 은(는) 문자장치입니다."
elif [ -b "$filename" ]; then
    echo "$filename 은(는) 블록장치입니다."
elif [ -p "$filename" ]; then
    echo "$filename 은(는) 파이프입니다."
elif [ -S "$filename" ]; then
    echo "$filename 은(는) 소켓입니다."
elif [ -f "$filename" ]; then
    echo "$filename 은(는) 보통파일입니다."
else
    echo "$filename 은(는) 알 수 없는 유형입니다."
fi
